# syntax=docker/dockerfile:1

# Select base image
FROM ubuntu:24.04

# Disable prompt during packages installation
ARG DEBIAN_FRONTEND=noninteractive

# Add '/root/.cargo/bin' to path; this is required sind '.cargo/env' cannot easily be sourced in the docker image
ENV PATH="/root/.cargo/bin:$PATH"

# Minimize the number of layers (RUN, COPY and ADD create layers)
# https://docs.docker.com/develop/develop-images/dockerfile_best-practices/#minimize-the-number-of-layers
RUN echo "#### Installing dependencies" \
  && apt update \
  && apt install -y \
       gnupg \
       software-properties-common \
       wget \
  && mkdir -p /etc/apt/keyrings \
  && UBUNTU_CODENAME=$(. /etc/os-release && echo $VERSION_CODENAME) \
  && wget -O - https://apt.llvm.org/llvm-snapshot.gpg.key | gpg --dearmor -o /etc/apt/keyrings/llvm-snapshot.gpg \
  && touch /etc/apt/sources.list.d/llvm-snapshot.sources \
  && echo "Types: deb" | tee -a /etc/apt/sources.list.d/llvm-snapshot.sources \
  && echo "Architectures: amd64 arm64" | tee -a /etc/apt/sources.list.d/llvm-snapshot.sources \
  && echo "Signed-By: /etc/apt/keyrings/llvm-snapshot.gpg" | tee -a /etc/apt/sources.list.d/llvm-snapshot.sources \
  && echo "URIs: http://apt.llvm.org/$UBUNTU_CODENAME/" | tee -a /etc/apt/sources.list.d/llvm-snapshot.sources \
  && echo "Suites: llvm-toolchain-$UBUNTU_CODENAME-21" | tee -a /etc/apt/sources.list.d/llvm-snapshot.sources \
  && echo "Components: main" | tee -a /etc/apt/sources.list.d/llvm-snapshot.sources \
  && apt update \
  && apt install -y \
       clang-21 \
       clang-format-21 \
       clang-tidy-21 \
       cmake \
       curl \
       gcc \
       git \
       libacl1-dev \
  && rm -rf /var/lib/apt/lists/* \
  && apt clean \
  && ln -s /usr/bin/clang-21 /usr/bin/clang \
  && ln -s /usr/bin/clang++-21 /usr/bin/clang++ \
  && ln -s /usr/bin/clang-tidy-21 /usr/bin/clang-tidy \
  && ln -s /usr/bin/clang-format-21 /usr/bin/clang-format \
  && ln -s /usr/bin/llvm-21 /usr/bin/llvm \
  && ln -s /usr/bin/llvm-cov-21 /usr/bin/llvm-cov \
  && ln -s /usr/bin/llvm-profdata-21 /usr/bin/llvm-profdata \
  && echo "#### Install minimal Rust toolchain" \
  && curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --profile minimal --no-modify-path \
  && echo "#### Adding beta and nightly toolchain" \
  && rustup toolchain add \
       beta \
       nightly \
       1.89.0 \
  && echo "#### Adding more components like 'clippy', 'rustfmt', etc." \
  && rustup component add \
       clippy \
       llvm-tools \
       rustfmt \
  && echo "#### Installing cargo-nextest" \
  && cargo install cargo-nextest --locked \
  && echo "#### Installing cargo-audit" \
  && cargo install cargo-audit --locked \
  && echo "Installing grcov" \
  && cargo install grcov \
  && echo "Installing just" \
  && cargo install just \
  && echo "#### Creating users and groups required for tests" \
  && useradd testuser1 \
  && useradd testuser2 \
  && groupadd testgroup1 \
  && groupadd testgroup2

# Set additional environment variables, e.g. 'ENV FOO=BAR'
