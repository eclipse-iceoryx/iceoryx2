package(default_visibility = ["//visibility:public"])

load("@rules_rust//rust:defs.bzl", "rust_library")

filegroup(
    name = "all_srcs",
    srcs = glob(["**"]),
)

rust_library(
    name = "iceoryx2-cal-conformance-tests-common",
    srcs = glob(["src/**/*.rs"]),
    crate_features = select({
        "//:cfg_feature_std": [
            "std",
        ],
        "//conditions:default": [
        ],
    }),
    deps = [
        "//iceoryx2-cal:iceoryx2-cal",
        "//iceoryx2-cal/conformance-tests:iceoryx2-cal-conformance-tests",
        "//iceoryx2-bb/concurrency:iceoryx2-bb-concurrency",
        "//iceoryx2-bb/loggers:iceoryx2-bb-loggers",
        "//iceoryx2-bb/lock-free:iceoryx2-bb-lock-free",
        "//iceoryx2-bb/testing:iceoryx2-bb-testing",
        "//iceoryx2-pal/print:iceoryx2-pal-print",
    ],
    proc_macro_deps = [
        "//iceoryx2-bb/testing-macros:iceoryx2-bb-testing-macros",
    ],
)
