#### Common Setup

set REPO_ROOT [exec git rev-parse --show-toplevel]
cd ${REPO_ROOT}

source ${REPO_ROOT}/internal/end-to-end-testing/common.exp

#### Test Setup

set MAPPING integrations/ros2/tunnel-backend/end-to-end-tests/static_mapping.toml

# CDR of std_msgs/msg/String { data: "hello" }, as hex bytes:
#
#   00 01 00 00        CDR_LE encapsulation
#   06 00 00 00        string length (incl. NUL)
#   68 65 6c 6c 6f 00  "hello\0"
set HELLO_CDR "00 01 00 00 06 00 00 00 68 65 6c 6c 6f 00"

exec cargo build --bin iox2-service 2>@1
exec cargo build --manifest-path integrations/ros2/Cargo.toml \
    -p iceoryx2-integrations-ros2-tunnel-backend --example tunnel_static_mapping 2>@1

#### Test

set timeout 30

# Start the tunnel with the mapping configuration
spawn cargo run --manifest-path integrations/ros2/Cargo.toml \
    -p iceoryx2-integrations-ros2-tunnel-backend --example tunnel_static_mapping -- ${MAPPING}
set id_tunnel $spawn_id
expect_output_from $id_tunnel "Local Discovery via Tracker"

# Create the mapped iceoryx2 service so the tunnel opens the bridge and creates
# the ROS 2 endpoints with the configured QoS.
spawn cargo run --bin iox2-service -- publish QosProbe \
    --type-name std_msgs/msg/String --type-variant DYNAMIC \
    --type-size 1 --type-alignment 1 \
    --data-representation HUMANREADABLE \
    --message $HELLO_CDR \
    --repetitions 0 --time-between-messages 500
set id_publish $spawn_id

expect_output_from $id_tunnel "Opening bridge"

#### Test Assertion

# Wait for tunnel's endpoint (publisher) to be discovered in ROS 2.
for {set i 0} {$i < 30} {incr i} {
    if {![catch {exec ros2 topic info /qos_probe --verbose} out]
        && [string match "*Publisher count: 1*" $out]} {
        break
    }
    exec sleep 0.5
}

# Assert the mapped QoS on the ROS 2 endpoint.
spawn ros2 topic info /qos_probe --verbose
set id_info $spawn_id
expect_outputs_from_any_order $id_info {
    "Reliability: BEST_EFFORT"
    "Durability: TRANSIENT_LOCAL"
    "Deadline: 500000000 nanoseconds"
}

#### Shutdown

send -i $id_publish $SIGINT
expect -i $id_publish eof

send -i $id_tunnel $SIGINT
expect_output_from $id_tunnel "exit"
expect -i $id_tunnel eof

show_test_passed
