#### Common Setup

set REPO_ROOT [exec git rev-parse --show-toplevel]
cd ${REPO_ROOT}

source ${REPO_ROOT}/internal/end-to-end-testing/common.exp

#### Test Setup

set timeout 30

#### Test

# Start a publisher so the service exists before hz tries to connect
spawn cargo run --example publish_subscribe_publisher
set id_publisher $spawn_id
expect_output_from $id_publisher {Send sample}

# Run hz with a timeout so it exits after collecting at least one stats window
spawn cargo run --bin iox2-service -- hz "My/Funk/ServiceName" --timeout 5 --window 5
set id_hz $spawn_id

#### Test Assertion

expect_output_from $id_hz {rate_hz:}

send -i $id_publisher $SIGINT
expect -i $id_publisher eof

show_test_passed
